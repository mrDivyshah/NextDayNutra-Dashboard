{
  "name": "nextdaynutra-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:ws": "node server.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:pull": "drizzle-kit pull",
    "db:generate": "drizzle-kit generate",
    "db:baseline": "node scripts/drizzle-baseline.mjs",
    "db:migrate": "drizzle-kit migrate",
    "db:deploy": "npm run db:generate && npm run db:migrate",
    "db:push:unsafe": "drizzle-kit push",
    "db:seed": "tsx src/db/seed.ts",
    "db:setup": "npm run db:deploy && npm run db:seed",
    "seed:admin": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@types/ws": "^8.18.1",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.577.0",
    "mysql2": "^3.19.1",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
